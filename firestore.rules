service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfilePath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasProfile() {
      return signedIn() && exists(userProfilePath());
    }

    function profile() {
      return get(userProfilePath()).data;
    }

    function isActive() {
      return hasProfile() && profile().active == true;
    }

    function isAdmin() {
      return isActive() && profile().role == 'Admin';
    }

    function isStaff() {
      return isActive() && profile().role == 'Staff';
    }

    function isTeam() {
      return isAdmin() || isStaff();
    }

    function isCustomer() {
      return isActive() && profile().role == 'customer';
    }

    function customerId() {
      return profile().customerId;
    }

    function validUserProfile(data) {
      return data.keys().hasOnly([
          'uid',
          'email',
          'name',
          'role',
          'customerId',
          'customerName',
          'active',
          'createdAt',
          'updatedAt'
        ])
        && data.uid is string
        && data.email is string
        && data.name is string
        && data.role in ['Admin', 'Staff', 'customer']
        && data.active is bool
        && data.createdAt is string
        && data.updatedAt is string
        && (!('customerId' in data) || data.customerId is string)
        && (!('customerName' in data) || data.customerName is string);
    }

    match /users/{userId} {
      allow get: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin()
        || (
          signedIn()
          && (
            resource.data.uid == request.auth.uid
            || resource.data.email == request.auth.token.email
          )
        );

      allow create: if signedIn()
        && validUserProfile(request.resource.data)
        && (
          isAdmin()
          || (
            request.auth.uid == userId
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.role == 'Admin'
            && request.resource.data.active == true
          )
        );

      allow update: if isAdmin()
        && validUserProfile(request.resource.data)
        && request.resource.data.uid == resource.data.uid;

      allow delete: if isAdmin() && request.auth.uid != resource.data.uid;
    }

    match /settings/{settingId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    match /customers/{customerDocId} {
      allow read: if isTeam() || (isCustomer() && customerDocId == customerId());
      allow create, update: if isTeam();
      allow delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isTeam() || (isCustomer() && resource.data.customerId == customerId());
      allow create, update: if isTeam();
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isTeam() || (isCustomer() && resource.data.customerId == customerId());
      allow create, update: if isTeam();
      allow delete: if isAdmin();
    }

    match /giftHistory/{giftId} {
      allow read, create, update: if isTeam();
      allow delete: if isAdmin();
    }

    match /giftItems/{giftItemId} {
      allow read: if isTeam();
      allow write: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read, create, update: if isTeam();
      allow delete: if isAdmin();
    }

    match /offers/{offerId} {
      allow read: if isTeam() || (isCustomer() && resource.data.isActive == true);
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
